1254', 1), (u'818', 2)]\n"}]}},{"text":"%md\n* b. Mostrar las películas cuya nota media sea superior a 3","user":"anonymous","dateUpdated":"2026-04-28T10:21:10+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"markdown","editOnDblClick":true},"editorMode":"ace/mode/markdown"},"settings":{"params":{},"forms":{}},"apps":[],"jobName":"paragraph_1777370470632_253644724","id":"20260428-100110_507787928","dateCreated":"2026-04-28T10:01:10+0000","status":"FINISHED","progressUpdateIntervalMs":500,"focus":true,"$$hashKey":"object:32141","dateFinished":"2026-04-28T10:21:10+0000","dateStarted":"2026-04-28T10:21:10+0000","results":{"code":"SUCCESS","msg":[{"type":"HTML","data":"<ul>\n<li>b. Mostrar las películas cuya nota media sea superior a 3</li>\n</ul>\n"}]}},{"text":"%pyspark\npeliculasBuenas = peliculasValoraciones.filter(lambda x: x[1] > 3)\n\nprint(peliculasBuenas.take(5))\n","user":"anonymous","dateUpdated":"2026-04-28T10:21:10+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{}},"settings":{"params":{},"forms":{}},"apps":[],"jobName":"paragraph_1777371531119_-655387755","id":"20260428-101851_29742489","dateCreated":"2026-04-28T10:18:51+0000","status":"FINISHED","progressUpdateIntervalMs":500,"focus":true,"$$hashKey":"object:32691","dateFinished":"2026-04-28T10:21:11+0000","dateStarted":"2026-04-28T10:21:11+0000","results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"[(u'1524', 4), (u'711', 4), (u'1492', 4), (u'661', 4), (u'1498', 4)]\n"}]}},{"text":"\n","user":"anonymous","dateUpdated":"2026-04-28T10:21:34+0000","config":{"colWidth":12,"enabled":true,"results":{},"editorSetting":{"language":"scala"},"editorMode":"ace/mode/scala"},"settings":{"params":{},"forms":{}},"apps":[],"jobName":"paragraph_1777371670826_783404565","id":"20260428-102110_1765650744","dateCreated":"2026-04-28T10:21:10+0000","status":"READY","progressUpdateIntervalMs":500,"focus":true,"$$hashKey":"object:34173"}],"name":"Tarea 18_1","i